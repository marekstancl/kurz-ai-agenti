            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                500,
                300
            ],
            "parameters": {
                "url": "https://api.coingecko.com/api/v3/coins/bitcoin/market_chart",
                "sendQuery": true,
