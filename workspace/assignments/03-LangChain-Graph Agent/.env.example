# === Required API Keys ===
OPENAI_API_KEY=sk-...                    # OpenAI API key for LLM + embeddings
TAVILY_API_KEY=tvly-...                  # Tavily API key (free: tavily.com)

# === Optional Settings ===
LLM_MODEL=gpt-4o-mini                   # LLM model (default: gpt-4o-mini)
QDRANT_URL=http://qdrant:6333           # Qdrant URL (for Docker Compose)
MAX_AGENT_ITERATIONS=10                  # Max ReAct loop iterations
